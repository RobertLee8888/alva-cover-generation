{
  "name": "@alva/cover-generation",
  "version": "1.0.0",
  "description": "Deterministic playbook cover generator for Alva's Explore grid. 4-template taxonomy, hash-derived bg, brand/portrait overrides, Figma Plugin API applicator.",
  "license": "UNLICENSED",
  "main": "src/cover-gen.ts",
  "types": "src/cover-gen.ts",
  "files": [
    "SKILL.md",
    "README.md",
    "src/",
    "references/",
    "examples/"
  ],
  "exports": {
    ".": {
      "types": "./src/cover-gen.ts",
      "default": "./src/cover-gen.ts"
    },
    "./color": "./src/color.ts",
    "./types": "./src/types.ts",
    "./figma-apply": "./src/figma-apply.ts",
    "./palette": "./src/palette.ts",
    "./brand-registry": "./src/brand-registry.ts",
    "./icon-mapping": "./src/icon-mapping.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "npm run validate:brands",
    "dev": "vite --config demo/vite.config.ts demo",
    "build": "vite build --config demo/vite.config.ts demo",
    "preview": "vite preview --config demo/vite.config.ts demo",
    "validate:brands": "tsx scripts/validate-brand-registry.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@figma/plugin-typings": "*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.0"
  },
  "keywords": [
    "alva",
    "cover",
    "playbook",
    "figma",
    "design-system",
    "explore"
  ],
  "engines": {
    "node": ">=18"
  }
}
